{% set slides = entry.carouselSlides.all %}

{% set carousel = {
    mode: 'crop',
    width: 650,
    height: 343,
    quality: 100
} %}

<!-- Slider main container -->
<div class="swiper">
  <!-- Additional required wrapper -->
  <div class="swiper-wrapper">
    <!-- Slides -->
    {% for slide in slides %}
      <div class="flex flex-col swiper-slide md:flex-row">
        {% set image = slide.image.one() %}

          {% set slideImage %}
            <img class="w-full" src="{{ image.url(carousel) }}" alt="{{ image.alternativeText|length ? image.alternativeText|length : image.title }}" />
          {% endset %}
        
          <div class="flex-shrink-0 block w-full md:w-1/2 lg:w-2/3">
            {% if slide.buttonLink.getUrl|length %}
              <a href="{{ slide.buttonLink }}">{{ slideImage }}</a>
            {% else %}
              {{ slideImage }}
            {% endif %}
          </div>
        {% if slide.caption|length or slide.description|length %}
          <div class="px-10 -mt-6 pb-6 pt-12 bg-brand-brown rounded-t-xl lg:absolute right-0 bottom-0 lg:h-[345px] lg:w-[485px]">
            <h2 class="mb-3 text-3xl font-bold text-white">{{ slide.caption }}</h2>
            <p class="mb-4 text-xl text-white">{{ slide.description }}</p>
            {% if slide.buttonLink|length %}
              <a class="inline-block text-xl font-bold text-white btn bg-brand-gold hover:bg-brand-blue" href="{{ slide.buttonLink }}">{{ slide.buttonLink.label }}</a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  <!-- If we need pagination -->
  {# <div class="swiper-pagination"></div> #}

  <!-- If we need navigation buttons -->
  <div class="swiper-button-prev flex items-center opacity-20 bg-gray-600 px-6 hover:opacity-60 transition-all duration-300 left-0 top-0 h-full translate-y-0 mt-0 text-white"></div>
  <div class="swiper-button-next flex items-center opacity-20 bg-gray-600 px-6 hover:opacity-60 transition-all duration-300 right-0 top-0 h-full translate-y-0 mt-0 text-white"></div> 
</div>

{# Minified Swiper CSS v7.3.1 #}
{% css "https://unpkg.com/swiper@7/swiper-bundle.min.css" %}

{# Minified Swiper JavaScript v7.3.1 #}
{% js "https://unpkg.com/swiper@7/swiper-bundle.min.js" %}

{% js %}
  documentReady(() => {
    //initialize swiper when document ready
    const swiper = new Swiper('.swiper', {
      // Optional parameters
      loop: true,
      speed: 900,

      autoplay: {
        delay: {{ entry.carouselInterval * 1000 }},
      },

      // If we need pagination
      // pagination: {
      //   el: '.swiper-pagination',
      // },

      // Navigation arrows
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },

      // And if we need scrollbar
      // scrollbar: {
      //   el: '.swiper-scrollbar',
      // },
    });

  });
{% endjs %}

