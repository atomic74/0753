{% cache globally %}
  {% set nav = siteOptions.mainNavigation.all %}
  {% apply spaceless %}
    <nav class="absolute left-0 top-[130px] z-10 hidden w-full bg-brand-brown lg:bg-transparent lg:w-auto lg:static lg:block" id="main-nav" role="menu" tabindex="-1">
      <ul class="list-none">
        {% for entry in nav %}
          <li class="lg:relative lg:inline-block group">
            <div class="flex items-center justify-between px-6 lg:px-0">
              <a class="flex-grow block py-3 text-2xl font-bold tracking-wide text-white transition-colors duration-300 ease-linear lg:px-8 lg:pt-6 lg:pb-4 lg:border-b-[10px] lg:border-b-transparent hover:lg:border-b-white/25 lg:focus:border-b-white/25 lg:inline-block" role="menuitem" href="{{ entry.url }}">
                {{ entry.title }}
              </a>
              {% if entry.getChildren|length %}
                <button type="button" aria-label="Main Navigation Subpages Toggle" title="Main Navigation Subpages Toggle" aria-expanded="false" aria-controls="main-navigation-subpages" _="on click toggle .hidden on the <div/> in me then toggle .hidden on the next <ul/>">
                  <div class="block px-4 text-white main-nav-chevron lg:hidden">
                    {{ svg("@webroot/img/icons/chevron-right-solid.svg")|attr({class: 'h-5 w-5 inline-block'}) }}
                  </div>
                  <div class="hidden px-4 text-white main-nav-chevron lg:hidden">
                    {{ svg("@webroot/img/icons/chevron-down-solid.svg")|attr({class: 'h-5 w-5 inline-block'}) }}
                  </div>
                </button>
              {% endif %}
            </div>
            {% set childPages = entry.getChildren().all %}
            {% if childPages | length %}
              <ul id="main-navigation-subpages" class="left-0 z-20 hidden w-full divide-y shadow-lg rounded-br-2xl divide-white/20 lg:absolute lg:w-64 lg:group-hover:block bg-brand-brown top-[82px]">
                {% for page in childPages %}
                  <li>
                    <a class="block py-3 text-xl text-white normal-case px-7 hover:bg-white/20" href="{{ page.url() }}">{{ page.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
        <li class="lg:hidden group">
          <div class="flex items-center justify-between px-6 lg:px-0">
            <a class="flex-grow block py-3 text-2xl font-bold tracking-wide text-white transition-colors duration-300 ease-linear lg:px-8 lg:pt-6 lg:pb-4 lg:hover:border-b-[10px] lg:border-b-white/25 lg:focus:border-b-white/25 lg:inline-block" role="menuitem" href="{{ url('about-mvyata/become-a-member') }}">
              Membership
            </a>
          </div>
        </li>
        <li class="lg:hidden group">
          <div class="flex items-center justify-between px-6 lg:px-0">
            <a class="flex-grow block py-3 text-2xl font-bold tracking-wide text-white transition-colors duration-300 ease-linear lg:px-8 lg:pt-6 lg:pb-4 lg:hover:border-b-[10px] lg:border-b-white/25 lg:focus:border-b-white/25 lg:inline-block" role="menuitem" href="{{ url('about-mvyata/brochures-and-forms') }}">
              Brochures and Forms
            </a>
          </div>
        </li>

      </ul>
    </nav>
  {% endapply %}
{% endcache %}
