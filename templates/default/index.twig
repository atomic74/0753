{# Homepage template #}

{% extends "_layouts/base" %}
{% set uri = entry.uri %}

{% block pageLayout %}
  {% embed '_layouts/page/homePage' %}
    {% block contentLayout %}
      <div class="main-content" id="main-content-start">
        <div class="bg-pattern-blue">
          <div class="xl:container">
            {% include '_partials/carousel' %}
          </div>
        </div>

        {# INTRO #}

        <div class="bg-white ">
          <div class="px-4 py-8 xl:container">
            <div class="grid grid-cols-1 gap-10 md:grid-cols-2">
              <div>
                <img class="block mb-5" src="{{ entry.introImage.one.getUrl() }}" alt="">
                <h1 class="mb-5 text-4xl font-bold md:text-5xl text-brand-wine">{{ entry.headline }}</h1>
                <div class="mb-5 text-lg md:text-2xl">{{ entry.hpIntroText }}</div>
                {% if entry.introButton|length %}
                  <a href="{{ entry.introButton }}" class="inline-block mr-4 text-xl font-bold text-white btn bg-brand-green hover:bg-brand-blue">{{ entry.introButton.label }}</a>
                  {% if entry.introButton2|length %}
                    <a href="{{ entry.introButton2 }}" class="inline-block text-xl font-bold text-white btn bg-brand-green hover:bg-brand-blue">{{ entry.introButton2.label }}</a>
                  {% endif %}
                {% endif %}
              </div>
              <div>
                {% set testimonial = craft.entries.section('testimonials').orderBy('RAND()').one %}
                <div class="max-w-full bg-cover h-[290px] rounded-t-xl" style="background-image:url('{{ entry.testimonialImage.one.getUrl({mode:'fit',width:645,quality:100,position:'center-center'}) }}')"></div>
                <div class="relative pt-[72px] px-[48px] pb-[35px] text-xl text-white bg-brand-blue rounded-br-2xl">
                  <div class="absolute top-5 left-5"><img src="/img/icon-before-quote.png" alt="Open quote graphic"></div>
                  <p class="">
                    {{ testimonial.quote }}
                  </p>
                  <p class="mt-6 italic font-bold">
                    {{ testimonial.title }}{% if testimonial.authorDescription %} &mdash; {{ testimonial.authorDescription }}{% endif %}
                  </p>
                  <div class="absolute bottom-5 right-5"><img src="/img/icon-after-quote.png" alt="Close quote graphic"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {# PROGRAMS #}

        <div class="bg-brand-beige">
          <div class="px-4 py-6 xl:container">
            <h2 class="text-4xl font-bold text-center md:text-5xl text-brand-wine">{{ entry.programsHeadline }}</h2>
            <div class="bg-chevron-line h-[11px] bg-repeat-x my-10 w-1/2 md:w-1/3 mx-auto"></div>
              <div class="grid grid-cols-1 gap-6 my-8 md:grid-cols-2 lg:grid-cols-4">
              {% for card in entry.homepageCards.all %}
                {% switch card.backgroundColor %}
                  {% case "gold" %}
                    {% set cardBgColor = 'bg-brand-gold' %}
                  {% case "green" %}
                    {% set cardBgColor = 'bg-brand-green' %}
                  {% case "purple" %}
                    {% set cardBgColor = 'bg-brand-purple' %}
                  {% case "wine" %}
                    {% set cardBgColor = 'bg-brand-wine' %}
                  {% default %}
                    {% set cardBgColor = 'bg-brand-blue' %}
                {% endswitch %}
                <a href="{{ card.linkTo }}" class="block rounded-tl-xl rounded-br-xl {{ cardBgColor }} hover:-translate-y-2 transition">
                  <div class="max-w-full bg-cover h-[180px] rounded-tl-xl" style="background-image:url('{{ card.image.one.getUrl({mode:'fit',width:600,quality:100,position:'center-center'}) }}')"></div>
                  <div class="p-5">
                    <div class="text-xl font-bold text-white">{{ card.heading }}</div>
                  </div>
                </a>
              {% endfor %}
            </div>
          </div>
        </div>

        {# GIVING #}

        <div class="py-10 -mb-8 bg-pattern-green">
          <div class="px-4 xl:container">
            <div class="items-center justify-start md:flex">
              <div class="md:w-1/2">
                <div class="max-w-full bg-cover w-[530px] h-[335px] rounded-xl mx-auto" style="background-image:url('{{ entry.givingImage.one.getUrl({mode:'fit',width:600,quality:100,position:'center-center'}) }}')"></div>
              </div>
              <div class="max-w-xl mt-6 md:ml-4 md:mt-0">
                <div class="mb-5 text-3xl text-white md:text-4xl">{{ entry.givingText }}</div>
                {% if entry.givingButton %}
                  <a href="{{ entry.givingButton }}" class="inline-block mr-4 text-xl font-bold text-white btn bg-brand-blue hover:bg-brand-wine">{{ entry.givingButton.label }}</a>
                  {% if entry.givingButton2 %}
                    <a href="{{ entry.givingButton2 }}" class="inline-block text-xl font-bold text-white btn bg-brand-blue hover:bg-brand-wine">{{ entry.givingButton2.label }}</a>
                  {% endif %}
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endblock %}
  {% endembed %}
{% endblock %}
