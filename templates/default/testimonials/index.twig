{% extends "_layouts/base" %}
{% set showSidebar = true %}
{% set pageHeading = entry.pageHeading|default(entry.title) %}

{% set testimonials = craft.entries.section('testimonials').limit(8).orderBy('RAND()').all %}

{% block pageLayout %}
  {% embed "_layouts/page/default" %}
    {% block mainHeading %}
      <div class="py-12 md:py-16 bg-pattern-blue">
        <div class="px-4 xl:px-0 xl:container">
          <h1 class="main-heading">{{ pageHeading }}</h1>
        </div>
      </div>
    {% endblock %}
    {% block contentLayout %}
      {% embed "_layouts/content/default" %}
        {% block mainContent %}
          {% if testimonials %}
            <div class="mt-10">
              {% for testimonial in testimonials %}
                {% if loop.index % 2 == 1 %}
                  <div class="relative pt-[72px] px-[48px] pb-[35px] text-xl text-white bg-brand-blue rounded-tl-2xl rounded-br-2xl">
                    <div class="absolute top-5 left-5"><img src="/img/icon-before-quote.png"></div>
                    <p class="">
                      {{ testimonial.quote }}
                    </p>
                    <p class="mt-6 italic font-bold">
                      {{ testimonial.firstName }} {{ testimonial.lastName|first }}.{% if testimonial.authorDescription %} &mdash; {{ testimonial.authorDescription }}{% endif %}
                    </p>
                    <div class="absolute bottom-5 right-5"><img src="/img/icon-after-quote.png"></div>
                  </div>
                {% else %}
                  <div class="p-8 text-xl">
                    <p class="">
                      {{ testimonial.quote }}
                    </p>
                    <p class="mt-6 italic font-bold text-brand-wine">
                      {{ testimonial.firstName }} {{ testimonial.lastName|first }}.{% if testimonial.authorDescription %} &mdash; {{ testimonial.authorDescription }}{% endif %}
                    </p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endblock %}
