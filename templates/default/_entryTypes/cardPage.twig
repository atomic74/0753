{% extends "_layouts/base" %}
{% set showSidebar = false %}
{% set pageHeading = entry.pageHeading|default(entry.title) %}
{% set pageHeading = entry.pageHeading|default(entry.title) %}
{% switch entry.headingBgColor %}
  {% case "gold" %}
    {% set headingBgPattern = 'bg-pattern-gold' %}
  {% case "green" %}
    {% set headingBgPattern = 'bg-pattern-green' %}
  {% case "purple" %}
    {% set headingBgPattern = 'bg-pattern-purple' %}
  {% case "wine" %}
    {% set headingBgPattern = 'bg-pattern-wine' %}
  {% default %}
    {% set headingBgPattern = 'bg-pattern-blue' %}
{% endswitch %}

{% block pageLayout %}
  {% embed "_layouts/page/default" %}
    {% block mainHeading %}
      <div class="py-12 md:py-16 {{ headingBgPattern }}">
        <div class="px-4 xl:px-0 xl:container">
          <h1 class="main-heading">{{ pageHeading }}</h1>
        </div>
      </div>
    {% endblock %}
    {% block contentLayout %}
      {% embed "_layouts/content/default" %}
        {% block mainContent %}
          {% if entry.intro is defined and entry.intro is not empty %}
            <div class="max-w-3xl mx-auto mt-8 text-2xl text-center">
              {{ entry.intro }}
            </div>
            <div class="bg-chevron-line h-[11px] bg-repeat-x my-10 w-1/2 md:w-1/3 mx-auto"></div>
          {% endif %}
          <div class="grid grid-cols-1 gap-6 my-8 md:grid-cols-2">
            {% for card in entry.cards.all %}
              {% switch card.backgroundColor %}
                {% case "gold" %}
                  {% set cardBgColor = 'bg-brand-gold' %}
                {% case "green" %}
                  {% set cardBgColor = 'bg-brand-green' %}
                {% case "purple" %}
                  {% set cardBgColor = 'bg-brand-purple' %}
                {% case "wine" %}
                  {% set cardBgColor = 'bg-brand-wine' %}
                {% default %}
                  {% set cardBgColor = 'bg-brand-blue' %}
              {% endswitch %}
              <a href="{{ card.linkTo }}" class="block rounded-tl-xl rounded-br-xl {{ cardBgColor }} hover:-translate-y-3 transition">
                <div class="max-w-full bg-cover h-[290px] rounded-tl-xl" style="background-image:url('{{ card.image.one.getUrl({mode:'fit',width:600,quality:100,position:'center-center'}) }}')"></div>
                <div class="p-8">
                  <h2 class="mb-4 text-2xl font-bold text-white">{{ card.heading }}</h2>
                  <div class="bg-white/30 w-[200px] h-1 my-4"></div>
                  <p class="mt-4 text-lg text-white">{{ card.description }}</p>
                </div>
              </a>
            {% endfor %}
          </div>
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endblock %}
